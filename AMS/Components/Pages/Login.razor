@page "/"
@page "/login"
@layout AMS.Components.Layout.BlankLayout
@using AMS.Domains.Dto
@using AMS.Services.DBService
@inject UserAccountService UserAccounts
@inject AMS.Services.SessionService.AuthSessionService Auth
@inject NavigationManager Nav

<PageTitle>Login</PageTitle>

<div class="login-page">
    <div class="login-backdrop-blur"></div>
    
    <div class="login-card">
        <div class="login-header">
            <img src="images/ju.jpg" class="login-logo" alt="JU Logo" />
            <h1 class="login-brand-title">AMS</h1>
            <p class="login-brand-subtitle">Attendance Management System<br />Educational Solutions</p>
        </div>

        <div class="login-body">
            <h2 class="login-section-label">Secure Institution Login</h2>

            <EditForm EditContext="editContext" OnSubmit="HandleSubmit" FormName="login">
                <DataAnnotationsValidator />

                @if (ShowAlert)
                {
                    <div class="alert alert-danger py-2 mb-3" role="alert" style="font-size: 0.9rem;">
                        @if (!string.IsNullOrWhiteSpace(error))
                        {
                            <div>@error</div>
                        }
                        <ValidationSummary class="mb-0" />
                    </div>
                }

                <div class="login-input-group">
                    <span class="login-input-icon"><i class="bi bi-person-fill"></i></span>
                    <InputText class="login-input" @bind-Value="model.Username" placeholder="Username / Email" />
                </div>

                <div class="login-input-group">
                    <span class="login-input-icon"><i class="bi bi-lock-fill"></i></span>
                    <input class="login-input" type="@PasswordInputType" value="@model.Password" @oninput="OnPasswordInput" placeholder="Password" />
                    <button class="login-input-toggle" type="button" @onclick="TogglePassword" aria-label="Toggle password visibility">
                        @if (showPassword)
                        {
                            <i class="bi bi-eye-slash-fill"></i>
                        }
                        else
                        {
                            <i class="bi bi-eye-fill"></i>
                        }
                    </button>
                </div>

                <a href="/forgot-password" class="forgot-password-link">Forgot Password?</a>
                <button class="login-btn login-btn-secondary" type="submit" disabled="@isBusy">
                    @(isBusy ? "Signing in..." : "Standard Login")
                </button>

                <div class="login-footer-row">
                    <label class="remember-me">
                        <input type="checkbox" class="form-check-input" /> Remember Me
                    </label>
                </div>

                <div class="contact-admin">
                    Don't have an account? <a href="mailto:admin@institution.edu">Contact Administrator</a>
                </div>
            </EditForm>
        </div>

        <!-- Tooltip for facial recognition - hidden on small screens -->
        <div class="facial-login-info d-none d-lg-flex">
            <div style="font-size: 24px; color: var(--login-primary);">
                <i class="bi bi-camera-fill"></i>
            </div>
            <div>
                For Facial Recognition login, please ensure your camera is enabled after clicking the button.
            </div>
        </div>
    </div>
</div>

@code {
    private readonly LoginDto model = new();
    private EditContext editContext;
    private bool isBusy;
    private string error = "";
    private bool submitAttempted;
    private bool hasValidationMessages;
    private bool showPassword;

    private string PasswordInputType => showPassword ? "text" : "password";

    protected override void OnInitialized()
    {
        editContext = new EditContext(model);
        editContext.OnValidationStateChanged += (_, __) =>
        {
            hasValidationMessages = editContext.GetValidationMessages().Any();
            StateHasChanged();
        };
    }

    private bool ShowAlert => submitAttempted && (hasValidationMessages || !string.IsNullOrWhiteSpace(error));

    private async Task HandleSubmit()
    {
        submitAttempted = true;
        error = "";
        hasValidationMessages = false;

        var isValid = editContext.Validate();
        hasValidationMessages = editContext.GetValidationMessages().Any();
        if (!isValid)
        {
            return;
        }

        isBusy = true;
        try
        {
            var user = await UserAccounts.Login(model);
            if (user is null)
            {
                error = "Invalid username or password.";
                return;
            }

            await Auth.SetSessionAsync(AMS.Services.SessionService.AuthSessionService.Create(
                user.Oid.ToString(),
                user.FullName,
                user.Username,
                user.UserType));
            Nav.NavigateTo("/dashboard");
        }
        catch
        {
            error = "Could not sign in. Please try again.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private void OnPasswordInput(ChangeEventArgs e)
    {
        model.Password = e.Value?.ToString() ?? "";
        editContext.NotifyFieldChanged(new FieldIdentifier(model, nameof(model.Password)));
    }

    private void TogglePassword()
    {
        showPassword = !showPassword;
    }
}
