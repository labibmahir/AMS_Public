@page "/users"
@using System.ComponentModel.DataAnnotations
@using AMS.Domains.Dto
@using AMS.Domains.Data
@using AMS.Domains.Entities
@using AMS.Services.DBService
@using AMS.Services.SessionService

@inject UserAccountService UserAccounts
@inject AuthSessionService Auth
@inject NavigationManager Nav

<PageTitle>User Management</PageTitle>

<h1 class="h3 mb-3">User Management</h1>

@if (isAuthorized)
{
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="card-title mb-0">System Users</h5>
                <button class="btn btn-primary" type="button" @onclick="OpenCreate">
                    + New User
                </button>
            </div>

            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Username</th>
                        <th>User Type</th>
                        <th style="width: 150px;" class="text-end">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (isLoading)
                    {
                        <tr>
                            <td colspan="4" class="text-muted py-4">Loading...</td>
                        </tr>
                    }
                    else if (items.Count == 0)
                    {
                        <tr>
                            <td colspan="4" class="text-muted py-4">No users found.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in items)
                        {
                            <tr>
                                <td class="fw-semibold">@user.FullName</td>
                                <td>@user.Username</td>
                                <td>
                                    <span class="badge @(user.UserType == Enums.UserType.Admin ? "bg-primary" : "bg-info")">
                                        @user.UserType
                                    </span>
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="() => OpenEdit(user)">
                                        Edit
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger ms-1" type="button" @onclick="() => ConfirmDelete(user)">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="text-muted">Verifying access...</div>
}

@if (isModalOpen)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@ModalTitle</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm EditContext="formEditContext" OnSubmit="HandleFormSubmit" FormName="user-form">
                        <DataAnnotationsValidator />

                        @if (ShowFormAlert)
                        {
                            <div class="alert alert-danger" role="alert">
                                @if (!string.IsNullOrWhiteSpace(formError))
                                {
                                    <div class="fw-semibold">@formError</div>
                                }
                                <ValidationSummary class="mb-0" />
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label">Full Name <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="formModel.FullName" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Username <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="formModel.Username" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Password <span class="text-danger">*</span></label>
                            <InputText type="password" class="form-control" @bind-Value="formModel.Password" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">User Type <span class="text-danger">*</span></label>
                            <InputSelect class="form-select" @bind-Value="formModel.UserType">
                                <option value="">-- Select Type --</option>
                                @foreach (var type in Enum.GetValues<Enums.UserType>())
                                {
                                    <option value="@type">@type</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <button class="btn btn-outline-secondary" type="button" @onclick="CloseModal">Cancel</button>
                            <button class="btn btn-primary" type="submit" disabled="@isSaving">
                                @(isSaving ? "Saving..." : "Save")
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private readonly List<UserAccount> items = new();
    private bool isLoading = true;
    private bool isAuthorized;

    private bool isModalOpen;
    private bool isEdit;
    private Guid editId;
    private bool isSaving;
    private string formError = "";
    private bool formSubmitAttempted;
    private bool formHasValidationMessages;

    private RegisterDto formModel = new();
    private EditContext formEditContext;

    protected override void OnInitialized()
    {
        InitForm();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var session = await Auth.GetSessionAsync();
            if (session is null || session.UserType != Enums.UserType.Admin)
            {
                Nav.NavigateTo("/dashboard");
                return;
            }

            isAuthorized = true;
            await LoadAsync();
            StateHasChanged();
        }
    }

    private string ModalTitle => isEdit ? "Update User" : "Create User";
    private bool ShowFormAlert => formSubmitAttempted && (formHasValidationMessages || !string.IsNullOrWhiteSpace(formError));

    private async Task LoadAsync()
    {
        isLoading = true;
        try
        {
            var result = await UserAccounts.GetUserAccounts();
            items.Clear();
            items.AddRange(result);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void InitForm()
    {
        formModel = new RegisterDto { UserType = Enums.UserType.Teacher };
        formEditContext = new EditContext(formModel);
        formEditContext.OnValidationStateChanged += (_, __) =>
        {
            formHasValidationMessages = formEditContext.GetValidationMessages().Any();
            StateHasChanged();
        };
    }

    private void OpenCreate()
    {
        isEdit = false;
        editId = Guid.Empty;
        formError = "";
        formSubmitAttempted = false;
        formHasValidationMessages = false;
        InitForm();
        isModalOpen = true;
    }

    private void OpenEdit(UserAccount u)
    {
        isEdit = true;
        editId = u.Oid;
        formError = "";
        formSubmitAttempted = false;
        formHasValidationMessages = false;

        formModel = new RegisterDto
        {
            FullName = u.FullName,
            Username = u.Username,
            Password = u.Password,
            UserType = u.UserType
        };
        formEditContext = new EditContext(formModel);
        formEditContext.OnValidationStateChanged += (_, __) =>
        {
            formHasValidationMessages = formEditContext.GetValidationMessages().Any();
            StateHasChanged();
        };

        isModalOpen = true;
    }

    private void CloseModal()
    {
        isModalOpen = false;
        isSaving = false;
    }

    private async Task HandleFormSubmit()
    {
        formSubmitAttempted = true;
        formError = "";
        formHasValidationMessages = false;

        var isValid = formEditContext.Validate();
        formHasValidationMessages = formEditContext.GetValidationMessages().Any();
        if (!isValid) return;

        isSaving = true;
        try
        {
            if (isEdit)
            {
                await UserAccounts.UpdateUserAccount(editId, formModel);
            }
            else
            {
                await UserAccounts.AddUserAccount(formModel);
            }

            CloseModal();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            formError = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ConfirmDelete(UserAccount u)
    {
        // Simple confirm for brevity in this example, user might want a proper modal later
        try 
        {
            await UserAccounts.DeleteUserAccount(u.Oid);
            await LoadAsync();
        }
        catch (Exception ex)
        {
             // error handling
        }
    }
}
