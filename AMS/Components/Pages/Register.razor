@page "/register"
@layout AMS.Components.Layout.BlankLayout
@using System.ComponentModel.DataAnnotations
@using AMS.Domains.Dto
@using AMS.Domains.Data
@using AMS.Services.DBService
@inject UserAccountService UserAccounts
@inject NavigationManager Nav

<PageTitle>Register</PageTitle>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <h1 class="h4 mb-1">Create account</h1>
        <p class="text-muted mb-4">Register a new user.</p>

        <EditForm EditContext="editContext" OnSubmit="HandleSubmit" FormName="register">
            <DataAnnotationsValidator />

            @if (ShowAlert)
            {
                <div class="alert alert-danger" role="alert">
                    @if (!string.IsNullOrWhiteSpace(error))
                    {
                        <div class="fw-semibold">@error</div>
                    }
                    <ValidationSummary class="mb-0" />
                </div>
            }

            <div class="mb-3">
                <label class="form-label">Full name <span class="text-danger">*</span></label>
                <InputText class="form-control" @bind-Value="model.FullName" />
            </div>

            <div class="mb-3">
                <label class="form-label">Username <span class="text-danger">*</span></label>
                <InputText class="form-control" @bind-Value="model.Username" />
            </div>

            <div class="mb-3">
                <label class="form-label">Password <span class="text-danger">*</span></label>
                <div class="input-group">
                    <input class="form-control" type="@PasswordInputType" value="@model.Password" @oninput="OnPasswordInput" />
                    <button class="btn btn-outline-secondary" type="button" @onclick="TogglePassword" aria-label="Toggle password visibility">
                        @if (showPassword)
                        {
                            <span class="d-inline-flex align-items-center" aria-hidden="true">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                                    <path d="M2.1 12s3.7-7 9.9-7 9.9 7 9.9 7-3.7 7-9.9 7-9.9-7-9.9-7Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                                    <path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" stroke="currentColor" stroke-width="2"/>
                                    <path d="M3 3l18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                </svg>
                            </span>
                        }
                        else
                        {
                            <span class="d-inline-flex align-items-center" aria-hidden="true">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                                    <path d="M2.1 12s3.7-7 9.9-7 9.9 7 9.9 7-3.7 7-9.9 7-9.9-7-9.9-7Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                                    <path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" stroke="currentColor" stroke-width="2"/>
                                </svg>
                            </span>
                        }
                    </button>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Confirm password <span class="text-danger">*</span></label>
                <div class="input-group">
                    <input class="form-control" type="@ConfirmPasswordInputType" value="@model.ConfirmPassword" @oninput="OnConfirmPasswordInput" />
                    <button class="btn btn-outline-secondary" type="button" @onclick="ToggleConfirmPassword" aria-label="Toggle confirm password visibility">
                        @if (showConfirmPassword)
                        {
                            <span class="d-inline-flex align-items-center" aria-hidden="true">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                                    <path d="M2.1 12s3.7-7 9.9-7 9.9 7 9.9 7-3.7 7-9.9 7-9.9-7-9.9-7Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                                    <path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" stroke="currentColor" stroke-width="2"/>
                                    <path d="M3 3l18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                </svg>
                            </span>
                        }
                        else
                        {
                            <span class="d-inline-flex align-items-center" aria-hidden="true">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                                    <path d="M2.1 12s3.7-7 9.9-7 9.9 7 9.9 7-3.7 7-9.9 7-9.9-7-9.9-7Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                                    <path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" stroke="currentColor" stroke-width="2"/>
                                </svg>
                            </span>
                        }
                    </button>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">User type <span class="text-danger">*</span></label>
                <InputSelect class="form-select" @bind-Value="model.UserType">
                    <option value="">-- Select Type --</option>
                    @foreach (var type in Enum.GetValues<Enums.UserType>())
                    {
                        <option value="@type">@type</option>
                    }
                </InputSelect>
            </div>

            <button class="btn btn-primary w-100" type="submit" disabled="@isBusy">
                @(isBusy ? "Creating..." : "Create account")
            </button>
        </EditForm>

        <div class="text-center mt-3">
            <a href="/login" class="text-decoration-none">Already have an account? Sign in</a>
        </div>
    </div>
</div>

@code {
    private readonly RegisterViewModel model = new();
    private EditContext editContext;
    private bool isBusy;
    private string error = "";
    private bool submitAttempted;
    private bool hasValidationMessages;
    private bool showPassword;
    private bool showConfirmPassword;

    private string PasswordInputType => showPassword ? "text" : "password";
    private string ConfirmPasswordInputType => showConfirmPassword ? "text" : "password";

    protected override void OnInitialized()
    {
        editContext = new EditContext(model);
        editContext.OnValidationStateChanged += (_, __) =>
        {
            hasValidationMessages = editContext.GetValidationMessages().Any();
            StateHasChanged();
        };
    }

    private bool ShowAlert => submitAttempted && (hasValidationMessages || !string.IsNullOrWhiteSpace(error));

    private async Task HandleSubmit()
    {
        submitAttempted = true;
        error = "";
        hasValidationMessages = false;

        var isValid = editContext.Validate();
        hasValidationMessages = editContext.GetValidationMessages().Any();
        if (!isValid)
        {
            return;
        }

        isBusy = true;
        try
        {
            if (!string.Equals(model.Password, model.ConfirmPassword, StringComparison.Ordinal))
            {
                error = "Passwords do not match.";
                return;
            }

            var dto = new RegisterDto
            {
                FullName = model.FullName,
                Username = model.Username,
                Password = model.Password,
                UserType = model.UserType ?? Enums.UserType.Teacher
            };

            await UserAccounts.AddUserAccount(dto);
            Nav.NavigateTo("/login");
        }
        catch (InvalidOperationException ex)
        {
            error = ex.Message;
        }
        catch (Exception ex)
        {
            error = string.IsNullOrWhiteSpace(ex.Message)
                ? "Could not create account. Please try again."
                : ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private void OnPasswordInput(ChangeEventArgs e)
    {
        model.Password = e.Value?.ToString() ?? "";
        editContext.NotifyFieldChanged(new FieldIdentifier(model, nameof(model.Password)));
    }

    private void OnConfirmPasswordInput(ChangeEventArgs e)
    {
        model.ConfirmPassword = e.Value?.ToString() ?? "";
        editContext.NotifyFieldChanged(new FieldIdentifier(model, nameof(model.ConfirmPassword)));
    }

    private void TogglePassword()
    {
        showPassword = !showPassword;
    }

    private void ToggleConfirmPassword()
    {
        showConfirmPassword = !showConfirmPassword;
    }

    private sealed class RegisterViewModel
    {
        [Required]
        [StringLength(250)]
        public string FullName { get; set; } = "";

        [Required]
        [StringLength(100)]
        public string Username { get; set; } = "";

        [Required]
        [StringLength(100)]
        public string Password { get; set; } = "";

        [Required]
        [StringLength(100)]
        public string ConfirmPassword { get; set; } = "";

        [Required]
        public Enums.UserType? UserType { get; set; }
    }
}
