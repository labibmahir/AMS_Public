@page "/classes"
@using System.ComponentModel.DataAnnotations
@using AMS.Domains.Dto
@using AMS.Domains.Entities
@using AMS.Services.DBService

@inject ClassService ClassDb
@inject UserAccountService UserAccounts
@inject NavigationManager Navigation
@inject AMS.Services.SessionService.AuthSessionService AuthSession

<PageTitle>Classes</PageTitle>

<h1 class="h3 mb-3">Classes</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-6">
                <label class="form-label">Search by name</label>
                <input class="form-control" placeholder="Type class name..." value="@search" @oninput="OnSearchInput" />
            </div>

            <div class="col-6 col-md-2">
                <label class="form-label">Page size</label>
                <select class="form-select" value="@pageSize" @onchange="OnPageSizeChange">
                    <option value="5">5</option>
                    <option value="10">10</option>
                    <option value="20">20</option>
                </select>
            </div>

            <div class="col-6 col-md-4 text-md-end">
                @if (session?.UserType == AMS.Domains.Data.Enums.UserType.Admin)
                {
                    <button class="btn btn-primary w-100 w-md-auto" type="button" @onclick="OpenCreate">
                        + New Class
                    </button>
                }
            </div>
        </div>

        <div class="table-responsive mt-3">
            <table class="table table-sm align-middle">
                <thead>
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>Class Name</th>
                    <th>Trainer</th>
                    <th style="width: 280px;" class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                @if (isLoading)
                {
                    <tr>
                        <td colspan="4" class="text-muted py-4 text-center">
                            <div class="spinner-border spinner-border-sm text-primary me-2"></div>Loading...
                        </td>
                    </tr>
                }
                else if (items.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="text-muted py-4 text-center">No classes found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var c in items)
                    {
                        <tr>
                            <td>@c.Oid</td>
                            <td class="fw-semibold">@c.ClassName</td>
                            <td>@c.FullName</td>
                            <td class="text-end text-nowrap">
                                <button class="btn btn-sm btn-info text-white" type="button" @onclick="() => ManageSchedule(c.Oid)">
                                    <i class="bi bi-calendar3 me-1"></i>Schedule
                                </button>
                                <button class="btn btn-sm btn-primary ms-1 text-white" type="button" @onclick="() => ManageAssignments(c.Oid)">
                                    <i class="bi bi-people me-1"></i>Students
                                </button>
                                @if (session?.UserType == AMS.Domains.Data.Enums.UserType.Admin)
                                {
                                    <button class="btn btn-sm btn-outline-secondary ms-1" type="button" @onclick="() => OpenEdit(c)">
                                        <i class="bi bi-pencil me-1"></i>Edit
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>

        <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center">
            <div class="text-muted small">
                @if (totalCount > 0)
                {
                    <span>Showing @StartIndex-@EndIndex of @totalCount</span>
                }
            </div>

            <div class="btn-group" role="group" aria-label="Pagination">
                <button class="btn btn-outline-secondary" type="button" disabled="@(pageNumber <= 1)" @onclick="PrevPage">Prev</button>
                <button class="btn btn-outline-secondary" type="button" disabled="true">
                    Page @pageNumber / @TotalPages
                </button>
                <button class="btn btn-outline-secondary" type="button" disabled="@(pageNumber >= TotalPages)" @onclick="NextPage">Next</button>
            </div>
        </div>
    </div>
</div>

@if (isModalOpen)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@ModalTitle</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm EditContext="formEditContext" OnSubmit="HandleFormSubmit" FormName="class-form">
                        <DataAnnotationsValidator />

                        @if (ShowFormAlert)
                        {
                            <div class="alert alert-danger" role="alert">
                                @if (!string.IsNullOrWhiteSpace(formError))
                                {
                                    <div class="fw-semibold">@formError</div>
                                }
                                <ValidationSummary class="mb-0" />
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label">Class Name <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="formModel.ClassName" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Trainer <span class="text-danger">*</span></label>
                            <InputSelect class="form-select" @bind-Value="formModel.UserId">
                                <option value="">-- Select Trainer --</option>
                                @foreach (var u in users)
                                {
                                    <option value="@u.Oid">@u.FullName</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <button class="btn btn-outline-secondary" type="button" @onclick="CloseModal">Cancel</button>
                            <button class="btn btn-primary" type="submit" disabled="@isSaving">
                                @(isSaving ? "Saving..." : "Save")
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private readonly List<ClassListDto> items = new();
    private readonly List<UserAccount> users = new();
    private bool isLoading = true;

    private string search = "";
    private int pageNumber = 1;
    private int pageSize = 10;
    private int totalCount;
    private AMS.Services.SessionService.AuthSessionService.UserSession session;

    private bool isModalOpen;
    private bool isEdit;
    private int editId;
    private bool isSaving;
    private string formError = "";
    private bool formSubmitAttempted;
    private bool formHasValidationMessages;

    private ClassFormModel formModel = new();
    private EditContext formEditContext;

    protected override async Task OnInitializedAsync()
    {
        session = await AuthSession.GetSessionAsync();
        InitForm();
        await LoadUsersAsync();
        await LoadAsync();
    }

    private async Task LoadUsersAsync()
    {
        try
        {
            var result = await UserAccounts.GetUserAccounts();
            users.Clear();
            users.AddRange(result);
        }
        catch
        {
            // ignore
        }
    }

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(totalCount / (double)Math.Max(1, pageSize)));
    private int StartIndex => totalCount == 0 ? 0 : ((pageNumber - 1) * pageSize) + 1;
    private int EndIndex => Math.Min(totalCount, pageNumber * pageSize);

    private string ModalTitle => isEdit ? "Update Class" : "Create Class";

    private bool ShowFormAlert => formSubmitAttempted && (formHasValidationMessages || !string.IsNullOrWhiteSpace(formError));

    private async Task LoadAsync()
    {
        isLoading = true;
        items.Clear();
        try
        {
            var result = await ClassDb.GetPaged(search, pageNumber, pageSize, 
                session?.UserId != null ? Guid.Parse(session.UserId) : null, 
                session?.UserType);
            totalCount = result.TotalCount;
            pageNumber = Math.Clamp(pageNumber, 1, TotalPages);
            items.AddRange(result.Items);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task PrevPage()
    {
        pageNumber = Math.Max(1, pageNumber - 1);
        await LoadAsync();
    }

    private async Task NextPage()
    {
        pageNumber = Math.Min(TotalPages, pageNumber + 1);
        await LoadAsync();
    }

    private async Task OnPageSizeChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size))
        {
            pageSize = size;
        }
        pageNumber = 1;
        await LoadAsync();
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        search = e.Value?.ToString() ?? "";
        pageNumber = 1;
        await LoadAsync();
    }

    private void InitForm()
    {
        formModel = new ClassFormModel();
        formEditContext = new EditContext(formModel);
        formEditContext.OnValidationStateChanged += (_, __) =>
        {
            formHasValidationMessages = formEditContext.GetValidationMessages().Any();
            StateHasChanged();
        };
    }

    private void ManageSchedule(int classId)
    {
        Navigation.NavigateTo($"/classes/{classId}/schedules");
    }

    private void ManageAssignments(int classId)
    {
        Navigation.NavigateTo($"/classes/{classId}/assignments");
    }

    private void OpenCreate()
    {
        isEdit = false;
        editId = 0;
        formError = "";
        formSubmitAttempted = false;
        formHasValidationMessages = false;
        InitForm();
        isModalOpen = true;
    }

    private void OpenEdit(ClassListDto c)
    {
        isEdit = true;
        editId = c.Oid;
        formError = "";
        formSubmitAttempted = false;
        formHasValidationMessages = false;

        formModel = new ClassFormModel
        {
            ClassName = c.ClassName,
            UserId = c.UserId
        };
        formEditContext = new EditContext(formModel);
        formEditContext.OnValidationStateChanged += (_, __) =>
        {
            formHasValidationMessages = formEditContext.GetValidationMessages().Any();
            StateHasChanged();
        };

        isModalOpen = true;
    }

    private void CloseModal()
    {
        isModalOpen = false;
        isSaving = false;
        formError = "";
        formSubmitAttempted = false;
        formHasValidationMessages = false;
    }

    private async Task HandleFormSubmit()
    {
        formSubmitAttempted = true;
        formError = "";
        formHasValidationMessages = false;

        var isValid = formEditContext.Validate();
        formHasValidationMessages = formEditContext.GetValidationMessages().Any();
        if (!isValid)
        {
            return;
        }

        var dto = new ClassUpsertDto
        {
            ClassName = formModel.ClassName,
            UserId = formModel.UserId
        };

        isSaving = true;
        try
        {
            if (isEdit)
            {
                await ClassDb.Update(editId, dto);
            }
            else
            {
                await ClassDb.Add(dto);
            }

            CloseModal();
            await LoadAsync();
        }
        catch (InvalidOperationException ex)
        {
            formError = ex.Message;
        }
        catch
        {
            formError = "Could not save. Please try again.";
        }
        finally
        {
            isSaving = false;
        }
    }

    private sealed class ClassFormModel
    {
        [Required]
        [StringLength(60)]
        public string ClassName { get; set; } = "";

        [Required]
        public Guid? UserId { get; set; }
    }

}
