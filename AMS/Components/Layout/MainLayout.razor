@inherits LayoutComponentBase
@inject AMS.Services.SessionService.AuthSessionService Auth
@inject NavigationManager Nav

<div class="page">
    <div class="sidebar @(isSidebarOpen ? "show" : "")">
        <NavMenu OnNavigate="CloseSidebar" />
    </div>

    <button class="mobile-menu-toggle" type="button" @onclick="ToggleSidebar" aria-label="Open navigation menu" aria-expanded="@isSidebarOpen">
        <i class="bi @(isSidebarOpen ? "bi-x-lg" : "bi-list")"></i>
    </button>

    @if (isSidebarOpen)
    {
        <button class="sidebar-backdrop" type="button" @onclick="CloseSidebar" aria-label="Close navigation menu"></button>
    }

    <main>
        <div class="top-row">
            <h1 class="topbar-title">Attendance Management System</h1>
            
            <div class="top-actions">
                <button class="top-icon-btn" title="Chat">
                    <i class="bi bi-chat-dots"></i>
                </button>
                
                <button class="top-icon-btn" title="Notifications">
                    <i class="bi bi-bell"></i>
                    <span class="notification-badge">1</span>
                </button>
                
                @if (session is not null)
                {
                    <div class="dropdown">
                        <div class="user-profile-dropdown" @onclick="ToggleUserDropdown">
                            <img src="https://ui-avatars.com/api/?name=@(session.FullName)&background=0D8ABC&color=fff" class="user-avatar" alt="User Avatar" />
                            <div class="d-none d-md-block">
                                <span class="user-name">@session.FullName</span>
                                <i class="bi bi-chevron-down small ms-1"></i>
                            </div>
                        </div>
                        
                        @if (isUserDropdownVisible)
                        {
                            <div class="dropdown-menu-custom">
                                <div class="dropdown-item-custom"><i class="bi bi-person me-2"></i> Account</div>
                                <div class="dropdown-divider-custom"></div>
                                <div class="dropdown-item-custom text-danger" @onclick="LogoutAsync"><i class="bi bi-box-arrow-right me-2"></i> Logout</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <article class="content px-4">
            @if (!authChecked)
            {
                <div class="text-muted">Loading...</div>
            }
            else if (needsLoginRedirect)
            {
                <div class="text-muted">Redirecting to login...</div>
            }
            else
            {
                @Body
            }
        </article>
    </main>
</div>

@code {
    private bool authChecked;
    private bool needsLoginRedirect;
    private bool isRedirecting;
    private bool isUserDropdownVisible;
    private bool isSidebarOpen;
    private AMS.Services.SessionService.AuthSessionService.UserSession session;

    private void ToggleUserDropdown() => isUserDropdownVisible = !isUserDropdownVisible;
    private void ToggleSidebar() => isSidebarOpen = !isSidebarOpen;
    private void CloseSidebar() => isSidebarOpen = false;

    protected override void OnParametersSet()
    {
        // Any page using MainLayout is protected, but session is loaded via JS (async) after render.
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RefreshSessionAsync();
        }

        if (authChecked && needsLoginRedirect && !isRedirecting)
        {
            isRedirecting = true;
            await InvokeAsync(() => Nav.NavigateTo("/login", replace: true));
        }
    }

    private async Task RefreshSessionAsync()
    {
        session = await Auth.GetSessionAsync();
        authChecked = true;
        needsLoginRedirect = session is null;
        StateHasChanged();
    }

    private async Task LogoutAsync()
    {
        await Auth.ClearSessionAsync();
        session = null;
        needsLoginRedirect = true;
        CloseSidebar();
        await InvokeAsync(() => Nav.NavigateTo("/login", replace: true));
    }
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
